# Copy this file to .agent.env and fill in your credentials.
# .agent.env is gitignored and never committed.

# Provider + model
# MODEL_PROVIDER supports built-in pi-ai providers, e.g. anthropic, openai
MODEL_PROVIDER=anthropic
MODEL=claude-sonnet-4-20250514
# OpenAI example:
# MODEL_PROVIDER=openai
# MODEL=gpt-5.3-codex

# API keys (set the one required by MODEL_PROVIDER)
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
# OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Base URL override (optional, for proxy / compatible providers)
# BASE_URL=<YOUR_PROVIDER_BASE_URL>

# Backward-compatible provider-specific base URL vars (optional)
# ANTHROPIC_BASE_URL=<YOUR_ANTHROPIC_COMPATIBLE_URL>
# OPENAI_BASE_URL=<YOUR_OPENAI_COMPATIBLE_URL>
