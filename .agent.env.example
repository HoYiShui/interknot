# Copy this file to .agent.env and fill in your credentials.
# .agent.env is gitignored and never committed.

# API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Model ID (optional, default: claude-sonnet-4-20250514)
# MODEL=claude-sonnet-4-20250514

# Base URL (optional, for proxy / compatible providers)
# ANTHROPIC_BASE_URL=https://api.aigocode.com
